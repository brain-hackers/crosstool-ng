CT_CONFIG_VERSION="4"
CT_OBSOLETE=y
CT_DEBUG_CT=y
CT_DEBUG_CT_SAVE_STEPS=y
CT_STRIP_TARGET_TOOLCHAIN_EXECUTABLES=y
CT_ARCH_ARM=y
CT_ARCH_FLOAT_HW=y
CT_STATIC_TOOLCHAIN=y
CT_KERNEL_LINUX=y
CT_LINUX_V_4_15=y
CT_BINUTILS_V_2_26=y
CT_GLIBC_V_2_23=y
CT_GLIBC_EXTRA_CFLAGS="-Wno-missing-attributes -Wno-array-bounds -Wno-array-parameter -Wno-stringop-overflow -Wno-maybe-uninitialized -Wno-implicit-int"
CT_GLIBC_ENABLE_COMMON_FLAG=y
CT_GCC_V_5=y
CT_CC_LANG_CXX=y
CT_DEBUG_DUMA=y
CT_DEBUG_GDB=y
CT_GDB_V_8_3=y
CT_GDB_NATIVE=y
CT_DEBUG_LTRACE=y
CT_DEBUG_STRACE=y
CT_GMP_V_6_1=y
CT_GMP_EXTRA_CFLAGS="-std=gnu17"
CT_ISL_V_0_15=y
CT_NCURSES_EXTRA_CFLAGS="-std=gnu11"
CT_ZSTD_NEEDED=y
