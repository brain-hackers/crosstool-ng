CT_OBSOLETE=y
CT_DEBUG_CT=y
CT_DEBUG_CT_SAVE_STEPS=y
CT_LOCAL_TARBALLS_DIR="${CT_TOP_DIR}/src"
CT_PREFIX_DIR="${CT_TOP_DIR}/output/${CT_TARGET}"
CT_STRIP_TARGET_TOOLCHAIN_EXECUTABLES=y
CT_ARCH_FLOAT_HW=y
CT_ARCH_arm=y
# CT_ARCH_ARM_TUPLE_USE_EABIHF is not set
CT_STATIC_TOOLCHAIN=y
CT_KERNEL_linux=y
CT_KERNEL_V_3_14=y
CT_BINUTILS_V_2_22=y
CT_LIBC_GLIBC_V_2_15=y
CT_CC_GCC_V_4_6_4=y
CT_CC_LANG_CXX=y
CT_DEBUG_duma=y
CT_DEBUG_gdb=y
CT_GDB_NATIVE=y
CT_GDB_V_7_4=y
CT_DEBUG_ltrace=y
CT_DEBUG_strace=y
CT_GMP_V_5_0_2=y
CT_MPFR_V_3_1_0=y
CT_MPC_V_0_9=y
