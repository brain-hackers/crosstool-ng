CT_CONFIG_VERSION="4"
CT_OBSOLETE=y
CT_DEBUG_CT=y
CT_DEBUG_CT_SAVE_STEPS=y
CT_STRIP_TARGET_TOOLCHAIN_EXECUTABLES=y
CT_ARCH_ARM=y
CT_MULTILIB=y
CT_TARGET_CFLAGS="-ftls-model=local-exec"
CT_STATIC_TOOLCHAIN=y
CT_TARGET_VENDOR="none"
CT_BINUTILS_V_2_26=y
CT_BINUTILS_EXTRA_CONFIG_ARRAY="--disable-warn-rwx-segments"
CT_LIBC_NEWLIB_IO_C99FMT=y
CT_LIBC_NEWLIB_IO_LL=y
CT_LIBC_NEWLIB_IO_FLOAT=y
CT_LIBC_NEWLIB_DISABLE_SUPPLIED_SYSCALLS=y
CT_GCC_V_5=y
CT_CC_LANG_CXX=y
CT_DEBUG_GDB=y
CT_GDB_V_8_3=y
CT_GMP_V_6_1=y
CT_GMP_EXTRA_CFLAGS="-std=gnu17"
CT_ISL_V_0_15=y
CT_NCURSES_EXTRA_CFLAGS="-std=gnu11"
CT_COMP_LIBS_NEWLIB_NANO=y
CT_ZSTD_NEEDED=y
