CT_OBSOLETE=y
CT_DEBUG_CT=y
CT_DEBUG_CT_SAVE_STEPS=y
CT_LOCAL_TARBALLS_DIR="${CT_TOP_DIR}/src"
CT_PREFIX_DIR="${CT_TOP_DIR}/output/${CT_TARGET}"
CT_ARCH_arm=y
CT_MULTILIB=y
CT_TARGET_VENDOR="none"
CT_BINUTILS_V_2_22=y
CT_LIBC_NEWLIB_IO_C99FMT=y
CT_LIBC_NEWLIB_IO_LL=y
CT_LIBC_NEWLIB_IO_FLOAT=y
CT_LIBC_NEWLIB_DISABLE_SUPPLIED_SYSCALLS=y
CT_CC_GCC_V_4_6_4=y
CT_CC_LANG_CXX=y
CT_DEBUG_gdb=y
# CT_GDB_CROSS_PYTHON is not set
CT_GDB_V_7_4=y
CT_GMP_V_5_0_2=y
CT_MPFR_V_3_1_0=y
CT_MPC_V_0_9=y
